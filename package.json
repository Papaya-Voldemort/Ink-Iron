{
  "name": "wuxia-cli",
  "version": "1.0.0",
  "description": "A Wuxia-inspired terminal RPG built with Bun + TypeScript",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "check": "tsc --noEmit",
    "build:all": "mkdir -p builds/$npm_package_version && bun run build:linux && bun run build:windows && bun run build:macos",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./src/main.ts --outfile builds/$npm_package_version/ink-and-iron-v$npm_package_version-linux",
    "build:windows": "bun build --compile --target=bun-windows-x64 ./src/main.ts --outfile builds/$npm_package_version/ink-and-iron-v$npm_package_version-windows.exe",
    "build:macos": "bun build --compile --target=bun-macos-arm64 ./src/main.ts --outfile builds/$npm_package_version/ink-and-iron-v$npm_package_version-macos-arm64"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^5.0.0"
  }
}