{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,

    // Bun / modern bundler mode
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Important for Bun globals like console, Bun, etc.
    "types": ["bun-types"],

    // Best practices (kept but slightly relaxed for sanity)
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Reduce noise in CLI projects
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // JSX removed on purpose (not needed for CLI)
    "jsx": "react-jsx"
  }
}